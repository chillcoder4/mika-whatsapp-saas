# ==============================================
# Joyz WhatsApp SaaS - Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to version control!

# ──────────────────────────────────────────────
# Firebase Web Configuration (from Firebase Console → Project Settings)
# ──────────────────────────────────────────────
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebasedatabase.app
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ──────────────────────────────────────────────
# Firebase Service Account (Backend Admin SDK)
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# ──────────────────────────────────────────────
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=000000000000000000000
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ──────────────────────────────────────────────
# AI API Keys
# ──────────────────────────────────────────────

# Primary Groq API Key (REQUIRED) — Get free key from https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: Secondary Groq keys for failover (Highly Recommended for scale)
GROQ_PRIMARY=gsk_primary_key_here
GROQ_SECONDARY=gsk_secondary_key_here
GROQ_3=gsk_third_key_here
GROQ_4=gsk_fourth_key_here
GROQ_5=gsk_fifth_key_here

# ──────────────────────────────────────────────
# Web Search (Serper.dev)
# ──────────────────────────────────────────────

# Optional: Serper.dev API Key for internet search
SERPER_API_KEY=your_serper_api_key_here
SERPER_API_KEY2=your_secondary_serper_api_key_here

# ──────────────────────────────────────────────
# Server Configuration
# ──────────────────────────────────────────────
PORT=3000
